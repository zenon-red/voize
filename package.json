{
  "name": "@zenon-red/voize",
  "version": "1.0.0",
  "description": "MCP server for TTS generation and storage-backed public audio URLs",
  "type": "module",
  "bin": {
    "voize-mcp": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "rm -rf build/ && tsc && chmod 755 build/index.js",
    "dev": "tsc --watch",
    "lint": "oxlint src/",
    "typecheck": "tsc --noEmit",
    "smoke": "bun run scripts/mcp-smoke.mjs",
    "smoke:live": "bun run scripts/mcp-smoke.mjs --live"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.914.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.9.1",
    "oxlint": "^1.50.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "MIT"
}
