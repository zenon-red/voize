# Optional: override MiMo API base URL (default is Token Plan AMS endpoint)
# MIMO_BASE_URL=https://token-plan-ams.xiaomimimo.com/v1

MIMO_API_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_DOMAIN=audio.zenon.red

MIMO_VOICE=mimo_default
MIMO_TIMEOUT_MS=30000
R2_REGION=auto

